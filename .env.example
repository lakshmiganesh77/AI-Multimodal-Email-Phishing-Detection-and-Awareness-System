# -------------------------------------------------------------------
# PhishGuard Production Environment Configuration Template
# -------------------------------------------------------------------
# Rename this file to .env and fill in your real secrets before running.
# DO NOT COMMIT THE REAL .env FILE TO VERSION CONTROL!

# [1] Core Application Settings
ENVIRONMENT=production
LOG_LEVEL=INFO

# [2] Authentication Keys (REQUIRED)
# Generate a secure key using: openssl rand -hex 32
JWT_SECRET_KEY="your-secure-64-character-jwt-signing-key"

# [3] Admin Account (REQUIRED)
# Set the password for the default "admin" account created on first run
ADMIN_PASSWORD="a-strong-admin-password"

# [4] Database Credentials (REQUIRED)
POSTGRES_PASSWORD="your-strong-postgres-password"
REDIS_PASSWORD="your-strong-redis-password"
# (DATABASE_URL and REDIS_URL are automatically constructed in docker-compose.yml using the passwords above)

# [5] Email Integration (OPTIONAL but recommended)
IMAP_SERVER="imap.gmail.com"
IMAP_EMAIL="your-test-email@gmail.com"
IMAP_PASSWORD="your-app-specific-password"

# [6] Threat Intelligence APIs (OPTIONAL but recommended)
VIRUSTOTAL_API_KEY="your-virustotal-api-key"
# PhishTank API is deprecated, but left here for legacy compatibility
PHISHTANK_API_KEY=""

# [7] Advanced ML Configuration
# Set to 'true' to run ML inference on a separate celery worker
USE_CELERY_WORKER=false
